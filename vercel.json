{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/**/*.ts": {
      "includeFiles": ["src/model/**", "server/lib/**"]
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
