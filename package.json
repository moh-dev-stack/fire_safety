{
  "name": "fire_saftey_poc",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,green \"npm run dev:api\" \"vite --host\"",
    "dev:vite": "vite",
    "dev:api": "tsx scripts/local-api.ts",
    "dev:all": "npm run dev",
    "dev:vercel": "npx --yes vercel@50 dev",
    "build": "tsc -b && vite build",
    "build:vercel": "npx --yes vercel@50 build --yes --prod",
    "lint": "eslint .",
    "test": "vitest run",
    "smoke": "node scripts/smoke.mjs",
    "test:watch": "vitest",
    "preview": "vite preview",
    "db:apply": "node scripts/apply-schema.mjs",
    "presentation:pdf": "cd presentation && npx --yes @marp-team/marp-cli --no-stdin --allow-local-files deck.md --pdf deck.pdf",
    "presentation:capture": "node presentation/capture-screenshots.mjs"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@vercel/blob": "^2.3.2",
    "jose": "^6.2.2",
    "leaflet": "^1.9.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.13.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.6",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.6.22",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "express": "^5.2.1",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "playwright": "^1.50.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.2"
  }
}
