# Copy to .env.local for Vercel CLI / local `vercel dev` (never commit secrets).
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Single shared login gate. Omit these to use defaults username 1234 / password 1234.
# Set different values in Vercel → Environment Variables for Production if needed.
AUTH_USERNAME=1234
AUTH_PASSWORD=1234

# Min 16 random bytes — used to sign session cookie (generate: openssl rand -hex 32)
SESSION_SECRET=change-me-min-16-chars-long-secret

# Vercel Cron: must match Authorization: Bearer … sent by Vercel when CRON_SECRET is set in project env.
CRON_SECRET=generate-a-long-random-secret

# Vercel Blob — create token in Vercel → Storage → Blob (required for scheduled CSV snapshots).
BLOB_READ_WRITE_TOKEN=
