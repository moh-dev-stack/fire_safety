# Copy to .env.local for local dev (never commit real secrets).
# For production/preview deploys, add the same keys in Vercel → Project → Settings → Environment Variables.

# This repo’s API uses DATABASE_URL only (pooled Neon URL is fine).
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Optional — Neon’s Vercel integration may also provide these (not read by this app’s code today).
# DATABASE_URL_UNPOOLED=
# PGHOST=
# PGHOST_UNPOOLED=
# PGUSER=
# PGDATABASE=
# PGPASSWORD=
# POSTGRES_URL=
# POSTGRES_URL_NON_POOLING=
# POSTGRES_USER=
# POSTGRES_HOST=
# POSTGRES_PASSWORD=
# POSTGRES_DATABASE=
# POSTGRES_URL_NO_SSL=
# POSTGRES_PRISMA_URL=

# Optional — which event from src/data/events.ts drives incident dates + header (default: jalsa-2026-islamabad).
# Use EVENT_ID for local API (dotenv); set VITE_EVENT_ID to the same value for the Vite client build.
# EVENT_ID=jalsa-2026-islamabad
# VITE_EVENT_ID=jalsa-2026-islamabad
# Test presets in repo: test-fire-drill-mar-2026, test-winter-ops-2026

# Login password is fixed in code (1234) for this POC — not configurable via env.

# Min 16 random bytes — used to sign session cookie (generate: openssl rand -hex 32)
SESSION_SECRET=change-me-min-16-chars-long-secret

# Vercel Cron: must match Authorization: Bearer … sent by Vercel when CRON_SECRET is set in project env.
CRON_SECRET=generate-a-long-random-secret

# Vercel Blob — create token in Vercel → Storage → Blob (incident photo uploads + optional CSV snapshots).
BLOB_READ_WRITE_TOKEN=

# Optional — Vite client feature flags (default: enabled). Set to "false" to hide routes + nav.
# VITE_ENABLE_TRAINING=
# VITE_ENABLE_VENUE_CHECKLIST=
